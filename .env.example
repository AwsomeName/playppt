# Server
PORT=3001
NODE_ENV=development
# 讲解换页：manual | auto
PPT_DEFAULT_ADVANCE_MODE=auto
# 自动模式下，TTS 播完后倒计时秒数再发 COUNTDOWN_END 翻页
PPT_AUTO_ADVANCE_SEC=3
# 设为 false 可关闭 TTS 播放与 narration 回传，仅保留 FSM/翻页
NARRATION_TTS_ENABLED=true

# AI Provider：volc | openai | mock。默认优先火山云；OpenAI/mock 保留降级。
AI_PROVIDER=volc

# 火山云语音配置；也可只放在本机 local.properties（不要提交真实密钥）。
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
VOLC_SECRET_KEY=
VOLC_TTS_RESOURCE_ID=seed-tts-2.0
VOLC_TTS_SPEAKER=zh_female_meilinvyou_saturn_bigtts
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
# VOLC_TTS_ENDPOINT=wss://openspeech.bytedance.com/api/v3/tts/unidirectional/stream
# VOLC_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel

# 可选；作为 OpenAI fallback：TTS 拉取 gpt-4o-mini-tts，ASR/QA 可走 OpenAI。
OPENAI_API_KEY=
# ASR（audio/transcriptions 模型，无 Key 时走占位转写，见 2.1D）
ASR_MODEL=whisper-1
# M4 问答：Chat Completions 模型（无 Key / 超时 / 连续 5xx 时走检索降级，见 2.1D）
LLM_MODEL=gpt-4.1-mini
# 单次问答 LLM 请求超时（毫秒），默认 15000
QA_LLM_TIMEOUT_MS=15000
# M5：会话审计 NDJSON 目录（默认仓库根下 var/session-logs）
# PPT_SESSION_LOG_DIR=
# 演示稿目录，默认 presentations/
# PPT_PRESENTATIONS_DIR=

# 为 true 时允许 PUT /api/presentations/:id/scripts 与 kb（仅本机联调建议开启）
# PPT_PRESENTATION_EDITOR=false

# PPTX 转幻灯片图片（需 LibreOffice + poppler-utils）
# 设 false 则跳过转换，前端纯文本展示
PPT_LIBREOFFICE_CONVERT=true
# 转换超时（毫秒），默认 60000
# PPT_CONVERT_TIMEOUT_MS=60000
# 转换 DPI（72-300），默认 150
# PPT_CONVERT_DPI=150

# Frontend (Vite) — proxied API base in dev; see apps/web/vite.config.ts
VITE_API_BASE=http://localhost:3001
