# local.properties 示例（拷贝为 local.properties 后填入真实值；本文件可提交，local.properties 不可提交）
#
# 加载顺序：apps/server 启动时先读环境变量 / .env，缺失再回退到本文件。
# 适合存放「不希望提交进 Git 的本机敏感密钥」，与 .env.example 字段含义一致。
# 完整字段说明见 .env.example 与 docs/project.md。

# ===== 火山豆包大模型（默认 AI_PROVIDER=volc 时使用）=====
# 控制台：https://console.volcengine.com/speech/app
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
VOLC_SECRET_KEY=

# TTS 资源与音色
# seed-tts-2.0 仅认 *_uranus_bigtts 后缀的「豆包 2.0」音色；
# *_saturn_bigtts / *_moon_bigtts / 普通 *_bigtts 是 1.0 音色，会被服务端拒绝并回 55000000。
VOLC_TTS_RESOURCE_ID=seed-tts-2.0
VOLC_TTS_SPEAKER=zh_female_meilinvyou_uranus_bigtts

# ASR 资源（不改可省略）
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# ===== OpenAI（AI_PROVIDER=openai 或火山降级时使用，可选）=====
OPENAI_API_KEY=

# ===== LLM 模型名（可选）=====
# 优先读取 LLM_MODEL；缺失时回退到 MODEL。火山豆包模型示例：doubao-seed-2-0-lite-260215
# OpenAI 示例：gpt-4.1-mini
MODEL=
